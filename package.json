{
  "name": "@pedra-ai/sdk",
  "version": "0.3.0",
  "description": "Official JavaScript/TypeScript SDK for the Pedra API — AI photo editing for real estate: virtual staging, renovation, room emptying, enhancement, sky replacement, object removal/blur, and video.",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pedra",
    "real-estate",
    "proptech",
    "virtual-staging",
    "home-staging",
    "renovation",
    "interior-design",
    "ai",
    "image-editing",
    "image-enhancement",
    "real-estate-photography",
    "sdk"
  ],
  "license": "MIT",
  "author": "Pedra <felix@pedra.ai> (https://pedra.ai)",
  "homepage": "https://github.com/pedra-ai/pedra-node#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pedra-ai/pedra-node.git"
  },
  "bugs": {
    "url": "https://github.com/pedra-ai/pedra-node/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "npm run build && node --test test/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "typescript": "^5.4.0"
  }
}
